open_files
	make empty array for files
	loop for a number of times specified by user
		open file at location specified by user and append it to array of files
	return array of files

close_files
	loop through array of files
		close file at current position in array
	return

parse_inputs
	make empty array to hold all parsed data
	loop through all files
		loop through all lines in current file
			split line at commas and append resulting array to parsed data array
	loop through each data entry
		set variable tracking if this entry causes an error to false
		loop through each field in this data entry
			call reformat and note errors on this field, saving returned value and validity
			check if this field was marked as causing an error
				update overall error variable to True
			replace original field data with the reformatted value
		append overall erorr as its own section to this data entry
	return all parsed data


reformat_and_note_errors
	attempt the following
		remove any random apostrophes from the current entry
		set temporary holder variables to empty arrays
		check if field index is for a start date or end date
			split entry at a space to separate date and time
			split date section at forward slash to get day month and year
			split time section at colon to get hour minute and second
			combine day month year hour minute and second into a single array
			set current entry to that combined array
		otherwise check if field index is for a start station or end station
			split entry at comma to separate station name and area
		otherwise check if field index is for the trip category
			split at open bracket to separate category label from time range
			split right portion at hyphen to isolate lower time bound
			split that result at close bracket to isolate upper time bound
			combine category label, lower bound, and upper bound into an array
			set current entry to that array
		otherwise
			wrap current entry in an array
		return current entry and that there were no errors
	run if any error occurred
		wrap current entry in an array unchanged
		return current entry and that there was an error


remove_random_apostrophe
	loop for number of data points in the entry
		create an empty string
		check if the first character of this data point is an apostrophe
			loop through every character in this data point except the first
				concatenate current character onto the new string
			replace this data point with the new string without the apostrophe
	return the processed data


run_validation_checks
	loop through all data entries
		check if this entry has already been marked as causing errors
			put this entry through call validations and update it with the result
	return data with validation marks applied


call_validations
	set dodgy data variable to false and append it to the current entry
	set new error variable to false
	call check distance lat and long on current entry
		if a new error was found update error field in entry
		if data was found to be dodgy update dodgy field in entry
	call check start hour on current entry
		if a new error was found update error field in entry
		if data was found to be dodgy update dodgy field in entry
	call check start month on current entry
		if a new error was found update error field in entry
		if data was found to be dodgy update dodgy field in entry
	call check trip duration on current entry
		if a new error was found update error field in entry
		if data was found to be dodgy update dodgy field in entry
	call check trip category with duration on current entry
		if a new error was found update error field in entry
		if data was found to be dodgy update dodgy field in entry
	call check if weekend on current entry
		if a new error was found update error field in entry
		if data was found to be dodgy update dodgy field in entry
	call check end date is after start date on current entry
		if a new error was found update error field in entry
		if data was found to be dodgy update dodgy field in entry
	call check trip time speed and distance on current entry
		if a new error was found update error field in entry
		if data was found to be dodgy update dodgy field in entry
	call check date exists on current entry
		if a new error was found update error field in entry
		if data was found to be dodgy update dodgy field in entry
	return the updated entry


check_distance_lat_and_long
	attempt the following
		find change in latitude by subtracting start latitude from end latitude
		find change in longitude by subtracting start longitude from end longitude
		use haversine formula to calculate distance from latitude longitude and earth radius
		check if the distance in the data is between 90% and 150% of the calculated haversine distance
			if it is return that data is not dodgy and causes no error
			otherwise return that data is dodgy but causes no error
	run if any error occurred
		return that data is dodgy and causes an error


check_start_hour
	attempt the following
		get hour from start date field
		get hour from start hour field
		check if both hours match
			return that data is not dodgy and causes no error
			otherwise return that data is dodgy but causes no error
	run if any error occurred
		return that data is dodgy and causes an error


check_start_month
	attempt the following
		check if the numeric month from the start date matches the month name in the start month field for each of the 12 months
			if a match is found return that data is not dodgy and causes no error
		if no months matched return that data is dodgy but causes no error
	run if any error occurred
		return that data is dodgy and causes an error


check_trip_duration
	attempt the following
		check if the start and end dates share the same day month and year
			find trip start as seconds past midnight
			find trip end as seconds past midnight
			find duration as the difference between end and start
			convert duration to minutes and check if it is within 10% of the listed duration
				if it is return that data is not dodgy and causes no error
				otherwise return that data is dodgy but causes no error
		otherwise check if start and end share the same month and year
			find the difference in days and convert it to seconds
			find start time in seconds past midnight
			find end time in seconds past midnight offset by the day difference
			calculate duration from those times
			convert to minutes and check if within 10% of listed duration
				if it is return that data is not dodgy and causes no error
				otherwise return that data is dodgy but causes no error
		otherwise check if start and end share the same year
			check if start month is april june september or november
				calculate time change using a 30 day month length in seconds
			otherwise check if start month is february
				call check leap year on the start date field
					if it is a leap year use a 29 day month length in seconds
					otherwise use a 28 day month length in seconds
			otherwise
				use a 31 day month length in seconds
			convert duration to minutes and check if it is within 10% of listed duration
				if it is return that data is not dodgy and causes no error
				otherwise return that data is dodgy but causes no error
	run if any error occurred
		return that data is dodgy and causes an error


check_trip_category_with_duration
	attempt the following
		check if trip duration falls between the lower and upper bounds of the trip category
			if it does return that data is not dodgy and causes no error
			otherwise return that data is dodgy but causes no error
	run if any error occurred
		return that data is dodgy and causes an error


check_if_weekend
	attempt the following
		check if day of week is saturday or sunday and the is weekend flag is not zero
			return that data is not dodgy and causes no error
		otherwise check if day of week is saturday or sunday and the is weekend flag is zero
			return that data is dodgy but causes no error
		otherwise check if the is weekend flag is not zero
			return that data is dodgy but causes no error
		otherwise
